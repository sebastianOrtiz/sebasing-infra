# =============================================================================
# Variables de entorno para sebasing.dev (produccion)
# Copiar a .env y configurar con valores reales.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=sebasing
POSTGRES_PASSWORD=CAMBIAR_PASSWORD_SEGURO
POSTGRES_DB=sebasing

# URL de conexion completa (usada por los servicios de aplicacion)
DATABASE_URL=postgresql://sebasing:CAMBIAR_PASSWORD_SEGURO@postgres:5432/sebasing

# --- Redis ---
REDIS_PASSWORD=CAMBIAR_REDIS_PASSWORD_SEGURO
REDIS_URL=redis://:CAMBIAR_REDIS_PASSWORD_SEGURO@redis:6379/0

# --- JWT (NexusCRM API) ---
# Generar con: openssl rand -hex 32
JWT_SECRET_KEY=CAMBIAR_JWT_SECRET_SEGURO

# --- Event-Driven Service ---
# API key para comunicacion interna entre nexus-crm-api y event-driven-service
# Generar con: openssl rand -hex 32
EVENT_SERVICE_API_KEY=CAMBIAR_EVENT_API_KEY_SEGURO

# --- CORS ---
# Origenes permitidos separados por coma
ALLOWED_ORIGINS=https://sebasing.dev,https://nexus-crm-dashboard.sebasing.dev,https://nexus-crm-api.sebasing.dev

# --- GitHub Container Registry ---
# Para autenticarse y hacer pull de imagenes privadas:
# docker login ghcr.io -u <usuario> -p <token>
